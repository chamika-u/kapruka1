├──────────┼───────────────────────────────────┤
│          ▼                                   │
│  ┌───────────────────────────────────────┐   │
│  │     API Route (route.ts)              │   │
│  │  ┌────────────┐  ┌────────────────┐   │   │
│  │  │ Vercel AI  │  │   MCP Client   │   │   │
│  │  │ streamText │◄─┤  (mcp.ts)      │   │   │
│  │  └────────────┘  └───────┬────────┘   │   │
│  └──────────────────────────┼────────────┘   │
│                             │ stdio          │
│                    npx mcp-remote            │
│                             │                │
├─────────────────────────────┼────────────────┤
│                             ▼                │
│         https://mcp.kapruka.com/mcp          │
│         (Live Kapruka MCP Server)            │
└──────────────────────────────────────────────┘
```

